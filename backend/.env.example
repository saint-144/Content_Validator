# Database
DATABASE_URL=mysql+pymysql://root:Validator@2024@localhost:3306/content_validator

# LLM Provider: "anthropic", "openai", or "gemini"
LLM_PROVIDER=gemini

# Anthropic Claude (recommended)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# OR OpenAI GPT-4V
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-your-openai-key-here

# OR Google Gemini
# LLM_PROVIDER=gemini
GOOGLE_API_KEY=

# File storage
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=100

# Matching thresholds (0-100)
PIXEL_MATCH_THRESHOLD=95
SEMANTIC_MATCH_THRESHOLD=72
SUSPECTED_MATCH_THRESHOLD=65

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:4200"]
